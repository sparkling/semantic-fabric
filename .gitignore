# Rust
/target/
**/*.rs.bk
# Cargo.lock untracked by choice (re-resolved per build; avoids lockfile churn)
/Cargo.lock

# OS / editor
.DS_Store
*.swp
*.swo

# Environment / secrets (source-DB connection strings, credentials)
.env
.env.local
.env.*.local

# Local source / test databases (generated — SQLite dev + conformance CI)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Agent / Claude Code / ruflo tooling runtime (per-developer, not source)
.claude/
.claude-flow/
.swarm/
.metaharness/
.mcp.json
agentdb.rvf
*.rvf
*.rvf.lock

# MetaHarness drop-in — keep the text/KB, drop the large media
docs/metaharness-dropin/for-humans/studio/*.m4a
docs/metaharness-dropin/for-humans/studio/*.png

# Handover docs — local-only session notes, not tracked
docs/handover/
.ruvnet-brain/

